# meta developer: @chatgpt_ai_ime_bot
# scope: hikka_only
# scope: gevent

from .. import loader, utils
from telethon.tl.types import Message
import asyncio

@loader.tds
class MaweiFarmMod(loader.Module):
    """Авто-фарм для бота Mawei (@MaweiTG_Bot)"""
    strings = {"name": "MaweiFarm"}

    async def client_ready(self, client, db):
        self.db = db
        self.client = client
        self.bot_id = "MaweiTG_Bot"
        self.active = self.db.get("MaweiFarm", "status", False)

    @loader.command()
    async def mawei(self, message: Message):
        """Включить/выключить авто-фарм Mawei"""
        self.active = not self.active
        self.db.set("MaweiFarm", "status", self.active)
        state = "✅ ВКЛЮЧЕН" if self.active else "❌ ВЫКЛЮЧЕН"
        await utils.answer(message, f"<b>[MaweiFarm]</b> Статус: {state}\n<i>Нажми кнопку 'Копать' в боте один раз, чтобы запустить цикл.</i>")

    @loader.watcher(only_messages=True, chats=["MaweiTG_Bot"])
    async def watcher(self, message: Message):
        if not self.active:
            return

        # Проверяем наличие кнопок в сообщении
        if message.buttons:
            for row in message.buttons:
                for button in row:
                    # Ищем кнопку "Копать" (поддерживает текст с эмодзи)
                    if "Копать" in button.text:
                        await asyncio.sleep(3) # Задержка 3 сек (анти-спам)
                        try:
                            await message.click(button)
                            return
                        except Exception:
                            pass
                    
                    # Ищем кнопку "Открыть кейс"
                    if "Открыть" in button.text or "Кейс" in button.text:
                        await asyncio.sleep(2)
                        try:
                            await message.click(button)
                            return
                        except Exception:
                            pass

    @loader.command()
    async def mstats(self, message: Message):
        """Проверить, работает ли скрипт"""
        state = "✅ Работает" if self.active else "❌ Спит"
        await utils.answer(message, f"<b>[MaweiFarm]</b> Текущее состояние: {state}")